# === API Keys ===
MODEL_API_KEY=your_meta_muse_spark_api_key
GEMINI_API_KEY=your_gemini_api_key_for_antigravity

# === Chrome Profile ===
# Use isolated debug profile (recommended, avoids locking your real Chrome)
CHROME_PROFILE_DIR=~/chrome-debug-profile
CHROME_PROFILE_NAME=Default
# Main Chrome (for CDP real-profile connection, advanced)
CHROME_MAIN_USER_DATA_DIR=~/Library/Application Support/Google/Chrome   # macOS
# CHROME_MAIN_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\User Data      # Windows
CHROME_MAIN_PROFILE=Profile 1

# === Credentials (never committed, chmod 600 on macOS) ===
CANVAS_USERNAME=your_canvas_email
CANVAS_PASSWORD=your_canvas_password
GMAIL_USERNAME=your_gmail
GMAIL_PASSWORD=your_gmail_password_or_app_password
