{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "meta": {
      "npm": "@ai-sdk/openai",
      "name": "Meta Spark Muse",
      "options": {
        "baseURL": "https://api.meta.ai/v1",
        "apiKey": "{env:MODEL_API_KEY}"
      },
      "models": {
        "muse-spark-1.1": {
          "name": "Muse Spark 1.1"
        }
      }
    },
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      }
    }
  }
}
